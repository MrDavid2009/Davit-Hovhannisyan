{
  "name": "Фото-Север — Печать документов",
  "short_name": "Фото-Север",
  "description": "Копи-центр в Раменском. Загрузи файл — мы распечатаем. Северное шоссе, 18.",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "display_override": ["standalone", "minimal-ui"],
  "background_color": "#0a0a14",
  "theme_color": "#f97316",
  "orientation": "portrait-primary",
  "lang": "ru",
  "dir": "ltr",
  "prefer_related_applications": false,
  "categories": ["business", "productivity"],
  "screenshots": [],
  "icons": [
    {
      "src": "/logo-192-v2.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/logo-192-v2.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "/logo-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/logo-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "share_target": {
    "action": "/share-target",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "files",
          "accept": ["image/*", "application/pdf", ".doc", ".docx", ".zip", ".rar"]
        }
      ]
    }
  }
}
